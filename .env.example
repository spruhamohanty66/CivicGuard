# ─────────────────────────────────────────────────────────────
# CivicGuard — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in your values.
# ".env.local" is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# OpenAI API Key (required)
# Used by: /api/classify-incident, /api/dispatch-assistant,
#          /api/field-report, /api/generate-report,
#          /api/simulate-call, /api/summarize
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Montgomery County SODA API App Token (optional)
# Increases the rate limit for the live incident feed.
# Get a free token at: https://data.montgomerycountymd.gov/profile/edit/developer_settings
MONTGOMERY_APP_TOKEN=your-app-token-here
